  "keyFeatures": [
    "Interactive CLI with beautiful prompts powered by @clack/prompts",
    "Multi-blockchain support (EVM and Solana)",
    "8 popular wallet providers pre-configured (RainbowKit, Privy, Dynamic, etc.)",
    "TypeScript + Next.js 14+ with App Router",
    "Tailwind CSS styling included",
    "Ready-to-use contract/program interaction hooks",
    "Automatic package manager detection (npm, yarn, pnpm, bun)",
    "Git repository initialization option",
    "Automatic dependency installation option",
    "Update notifications for new CLI versions"
  ],
  "publicApiSurface": [
    "npx create-nextjs-dapp [project-name]",
    "--chain, -c <chain> - Select blockchain (evm, solana)",
    "--wallet, -w <provider> - Select wallet provider",
    "--yes, -y - Skip prompts and use defaults",
    "--git - Initialize git repository",
    "--install - Install dependencies after creation",
    "--use-npm - Use npm as package manager",
    "--use-yarn - Use yarn as package manager",
    "--use-pnpm - Use pnpm as package manager",
    "--use-bun - Use bun as package manager",
    "--help, -h - Show help message",
    "--version, -v - Show version number",
    "EVM wallet providers: rainbowkit, connectkit, privy, dynamic, reown, thirdweb, getpara",
    "Solana wallet providers: wallet-adapter, privy, dynamic, reown, thirdweb"
  ]
}
